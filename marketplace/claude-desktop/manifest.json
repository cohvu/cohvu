{
  "mcpb_version": "0.1",
  "name": "cohvu",
  "display_name": "Cohvu",
  "version": "1.0.0",
  "description": "What if your agent's understanding didn't die with the context window?",
  "author": {
    "name": "Cohvu",
    "url": "https://cohvu.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cohvu/cohvu"
  },
  "homepage": "https://cohvu.com",
  "icon": "icon.png",
  "server": {
    "type": "node",
    "entry_point": "server/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/server/index.js"],
      "env": {
        "COHVU_TOKEN": "${user_config.api_token}"
      }
    }
  },
  "user_config": {
    "api_token": {
      "type": "string",
      "title": "API Token",
      "description": "Run npx cohvu login in your terminal. Your token is in ~/.cohvu/tokens.json",
      "sensitive": true,
      "required": true
    }
  }
}
